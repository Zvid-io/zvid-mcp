{
  "name": "@zvid/mcp",
  "version": "0.1.0",
  "description": "Official Zvid agent and MCP server — quality-first project authoring, validation, approval-aware rendering, and trusted automation profiles.",
  "mcpName": "io.zvid/mcp",
  "license": "MIT",
  "homepage": "https://zvid.io",
  "author": {
    "name": "Zvid",
    "email": "support@zvid.io",
    "url": "https://zvid.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zvid-io/zvid-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Zvid-io/zvid-mcp/issues",
    "email": "help@zvid.io"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
